GROQ_API_KEY=""
AGENTOPS_API_KEY=
# AgentOps Configuration - set to "true" to enable tracking (disabled by default)
AGENTOPS_ENABLED=false
# LLM Configuration - set to "local" for local API or "groq" for Groq
LLM_PROVIDER=local
# Local LLM API configuration (works with Ollama, LM Studio, etc.)
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234
